{
  "name": "@vite-plugin-opencode-assistant/opencode",
  "version": "1.0.7",
  "type": "module",
  "main": "lib/index.js",
  "module": "es/index.js",
  "types": "es/index.d.ts",
  "files": [
    "es",
    "lib"
  ],
  "exports": {
    ".": {
      "types": "./es/index.d.ts",
      "import": "./es/index.js",
      "require": "./lib/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "pagoda-cli build && vite build -c vite.plugin.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@vite-plugin-opencode-assistant/shared": "workspace:*",
    "execa": "^9.6.1"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.3.15",
    "vite": "^5.4.21"
  }
}
