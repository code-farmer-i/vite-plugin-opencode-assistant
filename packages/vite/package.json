{
  "name": "vite-plugin-opencode-assistant",
  "version": "1.0.36",
  "description": "Embed OpenCode Web UI in your Vite dev server for real-time code modification and preview",
  "type": "module",
  "main": "lib/index.js",
  "module": "es/index.js",
  "types": "es/index.d.ts",
  "files": [
    "es",
    "lib"
  ],
  "exports": {
    ".": {
      "types": "./es/index.d.ts",
      "import": "./es/index.js",
      "require": "./lib/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "pagoda-cli build && vite build -c vite.client.config.ts",
    "dev": "pagoda-cli dev",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.declaration.json --noEmit"
  },
  "keywords": [
    "vite",
    "plugin",
    "opencode",
    "ai",
    "assistant",
    "chat",
    "hmr",
    "real-time",
    "code-modification"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@vite-plugin-opencode-assistant/components": "workspace:*",
    "@vite-plugin-opencode-assistant/opencode": "workspace:*",
    "@vite-plugin-opencode-assistant/shared": "workspace:*",
    "unplugin-vue-inspector": "^2.4.0"
  },
  "peerDependencies": {
    "vite": ">=4.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "execa": "^9.6.1",
    "typescript": "^5.9.3",
    "vite": "^5.0.0",
    "vue": "^3.5.32",
    "vue-tsc": "^2.2.12"
  }
}
