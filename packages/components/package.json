{
  "name": "@vite-plugin-opencode-assistant/components",
  "version": "1.0.59",
  "description": "Reusable OpenCode widget components built with Pagoda CLI",
  "type": "module",
  "main": "lib/index.cjs",
  "module": "es/index.mjs",
  "types": "es/index.d.ts",
  "files": [
    "es",
    "lib"
  ],
  "exports": {
    ".": {
      "types": "./es/index.d.ts",
      "import": "./es/index.mjs",
      "require": "./lib/index.cjs"
    },
    "./style.css": "./lib/index.css"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": [
    "**/*.css",
    "**/*.vue"
  ],
  "scripts": {
    "build": "pagoda-cli build",
    "dev:site": "pagoda-cli site",
    "build:site": "pagoda-cli build-site",
    "test": "vitest run"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@vite-plugin-opencode-assistant/shared": "workspace:*",
    "css-selector-generator": "^3.9.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^29.0.2",
    "vitest": "^1.6.1",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.12"
  }
}
