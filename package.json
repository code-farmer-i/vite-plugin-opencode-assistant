{
  "name": "vite-plugin-opencode-assistant",
  "version": "1.0.4",
  "description": "Embed OpenCode Web UI in your Vite dev server for real-time code modification and preview",
  "main": "dist/vite/index.js",
  "types": "dist/vite/index.d.ts",
  "type": "module",
  "workspaces": [
    "example"
  ],
  "exports": {
    ".": {
      "import": "./dist/vite/index.js",
      "types": "./dist/vite/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc && npm run build:plugins",
    "build:plugins": "vite build --config vite.plugins.config.ts",
    "dev": "tsc --watch",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vite",
    "plugin",
    "opencode",
    "ai",
    "assistant",
    "chat",
    "hmr",
    "real-time",
    "code-modification"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "execa": "^9.6.1",
    "unplugin-vue-inspector": "^2.4.0"
  },
  "peerDependencies": {
    "vite": ">=4.0.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.3.15",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/vite-plugin-opencode.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/vite-plugin-opencode/issues"
  },
  "homepage": "https://github.com/your-username/vite-plugin-opencode#readme"
}
