{
  "name": "vite-plugin-opencode-assistant-workspace",
  "version": "1.0.4",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm --filter @vite-plugin-opencode-assistant/shared build && pnpm --filter @vite-plugin-opencode-assistant/opencode build && pnpm --filter vite-plugin-opencode-assistant build",
    "dev": "pnpm --filter vite-plugin-opencode-assistant dev",
    "dev:docs": "pnpm --filter @vite-plugin-opencode-assistant/docs dev",
    "build:docs": "pnpm --filter @vite-plugin-opencode-assistant/docs build",
    "test": "pnpm --filter vite-plugin-opencode-assistant test",
    "typecheck": "pnpm -r --if-present run typecheck"
  },
  "devDependencies": {
    "@pagoda-cli/core": "^1.0.0",
    "@pnpm/logger": "1000.0.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
