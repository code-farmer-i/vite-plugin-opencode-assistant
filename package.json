{
  "name": "vite-plugin-opencode-assistant-workspace",
  "version": "1.0.30",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm --filter @vite-plugin-opencode-assistant/shared build && pnpm --filter @vite-plugin-opencode-assistant/opencode build && pnpm --filter @vite-plugin-opencode-assistant/components build && pnpm --filter vite-plugin-opencode-assistant build",
    "dev:components": "pnpm --filter @vite-plugin-opencode-assistant/components dev:site",
    "dev:playground": "pnpm --filter @vite-plugin-opencode-assistant/docs dev",
    "build:docs": "pnpm --filter @vite-plugin-opencode-assistant/docs build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm --filter vite-plugin-opencode-assistant test",
    "typecheck": "pnpm -r --if-present run typecheck",
    "release": "node scripts/release.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@pagoda-cli/core": "^1.0.0",
    "@pnpm/logger": "1000.0.0",
    "@types/node": "^20.0.0",
    "enquirer": "^2.4.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "semver": "^7.7.4",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.58.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "vue-eslint-parser": "^10.4.0"
  }
}
